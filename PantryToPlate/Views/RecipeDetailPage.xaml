<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PantryToPlate.Core.ViewModels;assembly=PantryToPlate.Core"
             x:Class="PantryToPlate.Views.RecipeDetailPage"
             Title="{Binding Recipe.Name}">



    <ContentPage.Content>
        <ScrollView>
            <StackLayout Padding="20" Spacing="15">
                <Label Text="{Binding Recipe.Name}"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Frame CornerRadius="10" Padding="15" BackgroundColor="LightBlue">
                    <StackLayout Spacing="10">
                        <Label Text="Ingredients:" FontSize="18" FontAttributes="Bold" />
                        <CollectionView ItemsSource="{Binding Recipe.RequiredIngredients}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                        <Label Text="{Binding ., Converter={StaticResource BoolToCheckIconConverter}}"
                                               FontSize="16" />
                                        <Label Text="{Binding QuantityRequired}"
                                               FontSize="16" />
                                        <Label Text="{Binding Unit}"
                                               FontSize="16" />
                                        <Label Text="{Binding Ingredient.Name}"
                                               FontSize="16"
                                               FontAttributes="Bold" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </StackLayout>
                </Frame>

                <Frame CornerRadius="10" Padding="15" BackgroundColor="LightGreen">
                    <StackLayout Spacing="10">
                        <Label Text="Cooking Instructions:" FontSize="18" FontAttributes="Bold" />
                        <Label Text="{Binding Recipe.Instructions}"
                               FontSize="16"
                               LineBreakMode="WordWrap" />
                    </StackLayout>
                </Frame>

                <Button Text="Got it! I'm cooking this"
                        Command="{Binding CookRecipeCommand}"
                        BackgroundColor="Green"
                        TextColor="White"
                        FontSize="18"
                        HorizontalOptions="Fill"
                        IsEnabled="{Binding IsCooking, Converter={StaticResource InverseBoolConverter}}" />

                <Button Text="Delete Recipe"
                        Command="{Binding DeleteRecipeCommand}"
                        BackgroundColor="Red"
                        TextColor="White"
                        FontSize="18"
                        HorizontalOptions="Fill" />

                <ActivityIndicator IsRunning="{Binding IsCooking}"
                                 IsVisible="{Binding IsCooking}" />
            </StackLayout>
        </ScrollView>
    </ContentPage.Content>

</ContentPage>