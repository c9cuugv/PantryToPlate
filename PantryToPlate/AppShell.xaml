<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="PantryToPlate.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PantryToPlate"
    xmlns:views="clr-namespace:PantryToPlate.Views"
    Title="PantryToPlate">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent
                Title="Home"
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab Title="Pantry" Icon="pantry.png">
            <ShellContent
                Title="Pantry"
                ContentTemplate="{DataTemplate views:PantryPage}"
                Route="PantryPage" />
        </Tab>
        <Tab Title="Shopping List" Icon="shopping.png">
            <ShellContent
                Title="Shopping List"
                ContentTemplate="{DataTemplate views:ShoppingListPage}"
                Route="ShoppingListPage" />
        </Tab>
    </TabBar>

    <Shell.FlyoutBehavior>
        <OnPlatform x:TypeArguments="FlyoutBehavior">
            <On Platform="Android, iOS">Disabled</On>
        </OnPlatform>
    </Shell.FlyoutBehavior>

<!-- Continue with app shell routes configured in AppShell.xaml.cs -->
</Shell>
