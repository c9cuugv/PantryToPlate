<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:PantryToPlate.ViewModels"
             x:Class="PantryToPlate.MainPage"
             Title="Home">

    <ContentPage.BindingContext>
        <viewmodels:HomeViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Content>
        <StackLayout Padding="20" Spacing="10">
            <Label Text="Available Recipes"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Load Recipes"
                        Command="{Binding LoadRecipesCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />
                <Button Text="Add Recipe"
                        Command="{Binding CreateRecipeCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}" />
            </HorizontalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsLoading}"
                             IsVisible="{Binding IsLoading}" />

            <CollectionView ItemsSource="{Binding Recipes}"
                           SelectionMode="Single"
                           SelectionChanged="OnRecipeSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="10"
                               Padding="15"
                               Margin="5"
                               BackgroundColor="LightGray">
                            <StackLayout>
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding RequiredIngredients, Converter={StaticResource IngredientsToSummaryConverter}}"
                                       FontSize="14"
                                       TextColor="Gray" />
                            </StackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="No recipes available. Add some ingredients to your pantry!"
                   IsVisible="{Binding Recipes, Converter={StaticResource InverseBoolConverter}}"
                   HorizontalOptions="Center"
                   TextColor="Gray" />
        </StackLayout>
    </ContentPage.Content>

</ContentPage>
